{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Downward (symbolic)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/builds/symbolic/bin/downward",
      "args": [
        "--search",
        "symk_fw(silent=true,simple=true,plan_selection=top_k(num_plans=${input:numPlans},dump_plans=false))",
        "--internal-plan-file",
        "sas_plan",
      ],
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "stopAtEntry": false,
      "externalConsole": false,
      "preLaunchTask": "build-and-clean",
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true,
        },
        {
          "description": "Skips std lib code",
          "text": "skip -rfu ^std::",
        },
        {
            "description": "Skip timer.cc",
            "text": "skip -gfile /home/mbstarup/xDev/symk-groupings/src/search/utils/timer.cc",
            "ignoreFailures": true,
        },
        // { // Skips other random files for some reason lmao
        //     "description": "Skip cudd",
        //     "text": "skip -gfile ext/cudd-3.0.0/*",
        //     "ignoreFailures": true,
        // },
        // { // Skips other random files for some reason lmao
        //     "description": "Skip cache",
        //     "text": "skip -gfile /home/mbstarup/.cache/*",
        //     "ignoreFailures": true,
        // },
      ],
    },
  ],
  "inputs": [
    {
      "id": "numPlans",
      "type": "promptString",
      "description": "Enter k, to find top-k plans",
      "default": "10"
    },
  ],
}