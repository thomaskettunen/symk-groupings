{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-symbolic",
      "type": "shell",
      "command": "./build.py",
      "args": ["symbolic"],
      "group": "build",
      "problemMatcher": [],
    },
    {
      "label": "translate-symbolic",
      "type": "shell",
      "command": "./fast-downward.py",
      "args": [
        "--build", "symbolic",
        "--translate",
        "--keep-sas-file",
        "${input:domainFile}",
        "${input:problemFile}"
      ],
      "dependsOn": ["build-symbolic"],
      "dependsOrder": "sequence",
      "problemMatcher": [],
    }
  ],
  "inputs": [
    {
      "id": "domainFile",
      "type": "promptString",
      "description": "Enter path to domain PDDL file",
      "default": "../benchmarks/blocks/domain.pddl",
    },
    {
      "id": "problemFile",
      "type": "promptString",
      "description": "Enter path to problem PDDL file",
      "default": "../benchmarks/blocks/probBLOCKS-5-0.pddl",
    },
  ],
}